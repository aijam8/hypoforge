# ============================================================
#  HypoForge — environment configuration
#  Copy to ".env" and fill in. Only the LLM key is required.
# ============================================================

# Which LLM backend the agents use: gemini | deepseek | openrouter | mock
LLM_PROVIDER=gemini

# --- Gemini (free tier): get a key at https://aistudio.google.com/apikey ---
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- DeepSeek (cheap) ---
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# --- OpenRouter (many free/cheap models) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat

# Pipeline tuning
MAX_PAPERS_PER_SOURCE=8
NUM_HYPOTHESES=6
LLM_TEMPERATURE=0.5
